# DeepSeek API key for LLM requests.
DEEPSEEK_API_KEY=your-deepseek-api-key

# Chat backend: deepseek | openai | ollama (see dev.md / core/model_factory.py).
# LLM_MODEL_TYPE=deepseek

# Optional: Tavily search for fetch_url tool (non-URL queries). Usage logged + GET /api/usage
# TAVILY_API_KEY=

# Optional absolute or relative log file path.
# If empty and no --log-path is passed, defaults to backend/ace_claw.log.
ACE_CLAW_LOG_PATH=./backend/logs/ace_claw.log

# Optional directory that must contain .env at startup.
# When set, service startup will fail if <ACE_CLAW_ENV_DIR>/.env does not exist.
ACE_CLAW_ENV_DIR=./backend
